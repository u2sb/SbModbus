<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pvm="clr-namespace:SbModbus.Tool.ViewModels.Pages"
             xmlns:bh="clr-namespace:SbModbus.Tool.Utils.Behavior"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="SbModbus.Tool.Views.Pages.SerialPortAssistantPage"
             x:DataType="pvm:SerialPortAssistantPageViewModel"
             x:Name="Root">

  <Design.DataContext>
    <pvm:SerialPortAssistantPageViewModel />
  </Design.DataContext>

  <Grid ColumnDefinitions="240,*">
    <!-- 左侧区域 -->
    <Border Grid.Column="0" Margin="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
            BorderThickness="1">
      <Grid>
        <Grid.Styles>
          <Style Selector="TextBox">
            <Setter Property="Width" Value="140" />
            <Setter Property="Height" Value="30" />
          </Style>

          <Style Selector="ComboBox">
            <Setter Property="Width" Value="140" />
          </Style>
        </Grid.Styles>
        <StackPanel Margin="5">
          <Grid Height="40">
            <TextBlock Text="{StaticResource lang.dataInterface}" />
            <ComboBox
              SelectedIndex="{Binding DataTransferType,
                    Converter={StaticResource EnumToIntConverter}}">
              <ComboBoxItem Content="{StaticResource lang.noneType}" />
              <ComboBoxItem Content="{StaticResource lang.serialPortType}" />
              <ComboBoxItem Content="{StaticResource lang.tcpClientType}" />
              <ComboBoxItem Content="{StaticResource lang.tcpServerType}" />
              <ComboBoxItem Content="{StaticResource lang.udpClientType}" />
              <ComboBoxItem Content="{StaticResource lang.udpServerType}" />
            </ComboBox>
          </Grid>

          <Grid Height="40">
            <TextBlock Text="{StaticResource lang.connectionStatus}" />
            <Rectangle Width="130" Margin="5,0" Height="15" HorizontalAlignment="Right"
                       Fill="{Binding IsConnected, Converter={StaticResource BoolToColorBrushConverter}}" />
          </Grid>

          <Rectangle Margin="0,5" HorizontalAlignment="Stretch" Height="3" Fill="#1890FF" />

          <Grid
            IsVisible="{Binding DataTransferType,
                            Converter={StaticResource EnumToBoolConverter},
                            ConverterParameter=SerialPort }">
            <StackPanel>
              <Grid Height="40">
                <TextBlock Text="{StaticResource lang.protName}" />
                <ComboBox ItemsSource="{Binding SerialPortNames}"
                          SelectedValue="{Binding SerialPortName}" />
              </Grid>
              <Grid Height="40">
                <TextBlock Text="{StaticResource lang.baudRate}" />
                <TextBox Text="{Binding BaudRateString}" />
              </Grid>
              <Grid Height="40">
                <TextBlock Text="{StaticResource lang.dataBit}" />
                <ComboBox
                  ItemsSource="{Binding DataBitsValues}"
                  SelectedIndex="0"
                  SelectedValue="{Binding DataBits}" />
              </Grid>
              <Grid Height="40">
                <TextBlock Text="{StaticResource lang.parityBit}" />
                <ComboBox ItemsSource="{Binding ParityValues}"
                          SelectedIndex="{Binding Parity,
                    Converter={StaticResource EnumToIntConverter}}" />
              </Grid>
              <Grid Height="40">
                <TextBlock Text="{StaticResource lang.stopBit}" />
                <ComboBox ItemsSource="{Binding StopBitsValues}"
                          SelectedIndex="{Binding StopBits,
                    Converter={StaticResource EnumToIntConverter}}" />
              </Grid>
              <Grid Height="40">
                <TextBlock Text="{StaticResource lang.flowControl}" />
                <ComboBox
                  ItemsSource="{Binding HandshakeValues}"
                  SelectedIndex="{Binding Handshake,
                    Converter={StaticResource EnumToIntConverter}}" />
              </Grid>
              <UniformGrid Height="90" Rows="3" Columns="2">
                <TextBlock Text="DTR" />
                <ToggleSwitch OffContent="" OnContent="" HorizontalAlignment="Right"
                              IsChecked="{Binding DtrButton}" />
                <TextBlock Text="RTS" />
                <ToggleSwitch OffContent="" OnContent="" HorizontalAlignment="Right"
                              IsChecked="{Binding RtsButton}" />
                <TextBlock Text="Break" />
                <ToggleSwitch OffContent="" OnContent="" HorizontalAlignment="Right"
                              IsChecked="{Binding BreakButton}" />
              </UniformGrid>
            </StackPanel>
          </Grid>

          <Grid
            IsVisible="{Binding DataTransferType,
                            Converter={StaticResource EnumToBoolConverter},
                            ConverterParameter=TcpClient;UdpClient }">

            <StackPanel>
              <Grid Height="40">
                <TextBlock Text="{StaticResource lang.targetIp}" />
                <TextBox
                  Text="{Binding TargetIp}" />
              </Grid>
              <Grid Height="40">
                <TextBlock Text="{StaticResource lang.targetPort}" />
                <TextBox
                  Text="{Binding TargetPort}" />
              </Grid>
            </StackPanel>
          </Grid>

          <Grid
            IsVisible="{Binding DataTransferType,
                            Converter={StaticResource EnumToBoolConverter},
                            ConverterParameter=TcpServer;UdpServer }">
            <StackPanel>
              <Grid Height="40">
                <TextBlock Text="{StaticResource lang.localIp}" />
                <TextBox
                  Text="{Binding LocalIp}" />
              </Grid>
              <Grid Height="40">
                <TextBlock Text="{StaticResource lang.localPort}" />
                <TextBox
                  Text="{Binding LocalPort}" />
              </Grid>

              <Grid Height="100">
                <TextBlock Margin="0,30" VerticalAlignment="Top" Text="{StaticResource lang.targetClient}" />
                <ComboBox HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Height="35"
                          ItemsSource="{Binding Sessions}"
                          SelectedIndex="{Binding SelectedSessionIndex}" />
              </Grid>
            </StackPanel>
          </Grid>

          <StackPanel Margin="0,20" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Margin="10,0" Width="80" FontWeight="Bold"
                    Content="{StaticResource lang.btnConnect}"
                    Command="{Binding ConnectCommand}" />
            <Button Margin="10,0" Width="80" FontWeight="Bold"
                    Content="{StaticResource lang.btnDisConnect}"
                    Command="{Binding DisconnectCommand}" />
          </StackPanel>
        </StackPanel>
        <UniformGrid Margin="5,10" Columns="3" VerticalAlignment="Bottom" HorizontalAlignment="Stretch">
          <Button Margin="2" FontWeight="Bold"
                  Content="{StaticResource lang.btnClear}"
                  Command="{Binding CleanOutputCommand}" />
          <Button Margin="2" FontWeight="Bold"
                  Content="{Binding InputMode}"
                  Command="{Binding ChangeInputModeCommand}" />
          <Button Margin="2" FontWeight="Bold"
                  Content="{StaticResource lang.btnSend}"
                  Command="{Binding SendCommand}" />
        </UniformGrid>
      </Grid>
    </Border>
    <Border Grid.Column="1" Margin="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
            BorderThickness="1">
      <Grid RowDefinitions="*, 5, 180">
        <Grid Grid.Row="0">
          <Border>
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                          bh:SmartScrollBehavior.IsEnabled="True">
              <ItemsControl Classes="logNoSelect" ItemsSource="{Binding DsLogs}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0" ColumnDefinitions="Auto, 10, *">
                      <SelectableTextBlock Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left"
                                 FontSize="18"
                                 Foreground="CornflowerBlue"
                                 Text="{Binding DateTimeString}" />
                      <SelectableTextBlock Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Stretch"
                                           TextWrapping="Wrap" FontSize="18"
                                           Foreground="{Binding TextColor}"
                                           IsVisible="{Binding DataContext.UseHex,
                                            ElementName=Root}"
                                           Text="{Binding HexString}" />
                      <SelectableTextBlock Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Stretch"
                                           TextWrapping="Wrap" FontSize="18"
                                           Foreground="{Binding TextColor}"
                                           IsVisible="{Binding !DataContext.UseHex,
                                            ElementName=Root}"
                                           Text="{Binding Utf8String}" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </Grid>
        <GridSplitter Grid.Row="1" Height="2" MinHeight="1" Margin="5,0" Background="#1890FF"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center" ShowsPreview="True" />
        <Grid Grid.Row="2" RowDefinitions="*, 5, 110">
          <Border Grid.Row="0" Margin="5,2,5,2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  BorderThickness="1">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
              <SelectableTextBlock Margin="5" TextAlignment="Left" HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" TextWrapping="Wrap" FontSize="18"
                                   Text="{Binding OutputString}" />
            </ScrollViewer>
          </Border>
          <GridSplitter Grid.Row="1" Height="2" MinHeight="1" Margin="5,0" Background="#1890FF"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center" ShowsPreview="True" />
          <Border Grid.Row="2" Margin="5,2,5,5" BorderThickness="1" HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
            <TextBox Margin="5" Padding="0" BorderThickness="0" AcceptsReturn="True" TextWrapping="Wrap" FontSize="18"
                     VerticalAlignment="Stretch" HorizontalAlignment="Stretch" TextAlignment="Left" VerticalContentAlignment="Top"
                     Text="{Binding InputString, UpdateSourceTrigger=PropertyChanged}">
              <TextBox.Styles>
                <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                  <Setter Property="BorderThickness" Value="0" />
                </Style>
              </TextBox.Styles>
            </TextBox>
          </Border>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
